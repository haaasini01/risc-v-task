graph extension_sharing {
  rankdir=LR;
  node [shape=box, style=filled, fillcolor=lightyellow, fontname=Helvetica];
  edge [fontname=Helvetica, fontsize=9];

  subgraph cluster_legend {
    label="Legend";
    fontname=Helvetica;
    fontsize=11;
    style=filled;
    fillcolor=lightyellow;
    color=gray50;
    margin=12;

    legend_ext_a [label="Extension A", shape=box, style=filled, fillcolor=lightyellow, fontname=Helvetica, fontsize=10];
    legend_ext_b [label="Extension B", shape=box, style=filled, fillcolor=lightyellow, fontname=Helvetica, fontsize=10];
    legend_ext_a -- legend_ext_b [label="INSTR1,INSTR2+N", fontsize=9, style=dashed, color=gray40];

    legend_node_desc  [shape=plain, label="Node  = a RISC-V extension (e.g. rv_zbb)", fontname=Helvetica, fontsize=9];
    legend_edge_desc  [shape=plain, label="Edge  = two extensions share ≥1 instruction mnemonic", fontname=Helvetica, fontsize=9];
    legend_label_desc [shape=plain, label="Label = first 2 shared mnemonics, +N = additional count", fontname=Helvetica, fontsize=9];
  }

  rv32_zk [label="rv32_zk"];
  rv32_zkn [label="rv32_zkn"];
  rv32_zknd [label="rv32_zknd"];
  rv32_zkne [label="rv32_zkne"];
  rv32_zknh [label="rv32_zknh"];
  rv64_zbb [label="rv64_zbb"];
  rv64_zbkb [label="rv64_zbkb"];
  rv64_zk [label="rv64_zk"];
  rv64_zkn [label="rv64_zkn"];
  rv64_zknd [label="rv64_zknd"];
  rv64_zkne [label="rv64_zkne"];
  rv64_zknh [label="rv64_zknh"];
  rv64_zks [label="rv64_zks"];
  rv_zbb [label="rv_zbb"];
  rv_zbc [label="rv_zbc"];
  rv_zbkb [label="rv_zbkb"];
  rv_zbkc [label="rv_zbkc"];
  rv_zbkx [label="rv_zbkx"];
  rv_zk [label="rv_zk"];
  rv_zkn [label="rv_zkn"];
  rv_zknh [label="rv_zknh"];
  rv_zks [label="rv_zks"];
  rv_zksed [label="rv_zksed"];
  rv_zksh [label="rv_zksh"];
  rv_zvbb [label="rv_zvbb"];
  rv_zvkn [label="rv_zvkn"];
  rv_zvkned [label="rv_zvkned"];
  rv_zvknha [label="rv_zvknha"];
  rv_zvknhb [label="rv_zvknhb"];
  rv_zvks [label="rv_zvks"];
  rv_zvksed [label="rv_zvksed"];
  rv_zvksh [label="rv_zvksh"];

  rv32_zkn -- rv32_zknd [label="AES32DSI,AES32DSMI"];
  rv32_zkn -- rv32_zkne [label="AES32ESI,AES32ESMI"];
  rv32_zkn -- rv32_zknh [label="SHA512SIG0H,SHA512SIG0L+4"];
  rv32_zk -- rv32_zkn [label="AES32DSI,AES32DSMI+8"];
  rv32_zk -- rv32_zknd [label="AES32DSI,AES32DSMI"];
  rv32_zk -- rv32_zkne [label="AES32ESI,AES32ESMI"];
  rv32_zk -- rv32_zknh [label="SHA512SIG0H,SHA512SIG0L+4"];
  rv64_zbb -- rv64_zbkb [label="ROLW,RORI+2"];
  rv64_zbb -- rv64_zk [label="ROLW,RORI+2"];
  rv64_zbb -- rv64_zkn [label="ROLW,RORI+2"];
  rv64_zbb -- rv64_zks [label="ROLW,RORI+2"];
  rv64_zbkb -- rv64_zk [label="PACKW,ROLW+3"];
  rv64_zbkb -- rv64_zkn [label="PACKW,ROLW+3"];
  rv64_zbkb -- rv64_zks [label="PACKW,ROLW+3"];
  rv64_zknd -- rv64_zkne [label="AES64KS1I,AES64KS2"];
  rv64_zkn -- rv64_zknd [label="AES64DS,AES64DSM+3"];
  rv64_zkn -- rv64_zkne [label="AES64ES,AES64ESM+2"];
  rv64_zkn -- rv64_zknh [label="SHA512SIG0,SHA512SIG1+2"];
  rv64_zkn -- rv64_zks [label="PACKW,ROLW+3"];
  rv64_zk -- rv64_zkn [label="AES64DS,AES64DSM+14"];
  rv64_zk -- rv64_zknd [label="AES64DS,AES64DSM+3"];
  rv64_zk -- rv64_zkne [label="AES64ES,AES64ESM+2"];
  rv64_zk -- rv64_zknh [label="SHA512SIG0,SHA512SIG1+2"];
  rv64_zk -- rv64_zks [label="PACKW,ROLW+3"];
  rv_zbb -- rv_zbkb [label="ANDN,ORN+3"];
  rv_zbb -- rv_zk [label="ANDN,ORN+3"];
  rv_zbb -- rv_zkn [label="ANDN,ORN+3"];
  rv_zbb -- rv_zks [label="ANDN,ORN+3"];
  rv_zbc -- rv_zbkc [label="CLMUL,CLMULH"];
  rv_zbc -- rv_zk [label="CLMUL,CLMULH"];
  rv_zbc -- rv_zkn [label="CLMUL,CLMULH"];
  rv_zbc -- rv_zks [label="CLMUL,CLMULH"];
  rv_zbkb -- rv_zk [label="ANDN,ORN+5"];
  rv_zbkb -- rv_zkn [label="ANDN,ORN+5"];
  rv_zbkb -- rv_zks [label="ANDN,ORN+5"];
  rv_zbkc -- rv_zk [label="CLMUL,CLMULH"];
  rv_zbkc -- rv_zkn [label="CLMUL,CLMULH"];
  rv_zbkc -- rv_zks [label="CLMUL,CLMULH"];
  rv_zbkx -- rv_zk [label="XPERM4,XPERM8"];
  rv_zbkx -- rv_zkn [label="XPERM4,XPERM8"];
  rv_zbkx -- rv_zks [label="XPERM4,XPERM8"];
  rv_zkn -- rv_zknh [label="SHA256SIG0,SHA256SIG1+2"];
  rv_zkn -- rv_zks [label="ANDN,CLMUL+9"];
  rv_zks -- rv_zksed [label="SM4ED,SM4KS"];
  rv_zks -- rv_zksh [label="SM3P0,SM3P1"];
  rv_zk -- rv_zkn [label="ANDN,CLMUL+13"];
  rv_zk -- rv_zknh [label="SHA256SIG0,SHA256SIG1+2"];
  rv_zk -- rv_zks [label="ANDN,CLMUL+9"];
  rv_zvbb -- rv_zvkn [label="VANDN_VV,VANDN_VX+7"];
  rv_zvbb -- rv_zvks [label="VANDN_VV,VANDN_VX+7"];
  rv_zvknha -- rv_zvknhb [label="VSHA2CH_VV,VSHA2CL_VV+1"];
  rv_zvkn -- rv_zvkned [label="VAESDF_VS,VAESDF_VV+9"];
  rv_zvkn -- rv_zvknha [label="VSHA2CH_VV,VSHA2CL_VV+1"];
  rv_zvkn -- rv_zvknhb [label="VSHA2CH_VV,VSHA2CL_VV+1"];
  rv_zvkn -- rv_zvks [label="VANDN_VV,VANDN_VX+7"];
  rv_zvks -- rv_zvksed [label="VSM4K_VI,VSM4R_VS+1"];
  rv_zvks -- rv_zvksh [label="VSM3C_VI,VSM3ME_VV"];
}